
@using Gumani_Moila_ST10229429_CLDV7111w.Models
@using Gumani_Moila_ST10229429_CLDV7111w.Helpers
@model PaginatedList<Venue>

@{
    ViewData["Title"] = "Index";
}

<div class="w-full flex justify-between items-center mb-20 px-4">
    <a href="javascript:history.back()"
       class="inline-flex items-center px-3 py-2 rounded-lg bg-gray-200 text-gray-700 hover:bg-gray-300 transition-all shadow-sm">
        <i class="fa-solid fa-arrow-left mr-2"></i>
        <span>Back</span>
    </a>
    <a asp-action="Create" class="bg-blue-600 py-2 px-3 rounded text-white">Add venue</a>
</div>

@* // search box *@
<form asp-action="Index" method="get" id="searchForm"
      class="flex items-center flex-row gap-2 w-full px-4 py-2 rounded-lg border border-gray-300 focus:outline-none focus:ring-2 focus:ring-blue-500 mb-6">
    <input type="text" value="@ViewData["CurrentSearch"]" id="searchInput" name="searchInput"
           placeholder="Search by id,name,location,date..."
           class="flex-1 outline-none" />
    <div class="border-l-1 border-gray-300 pl-3">
        <i class="fa-solid fa-sliders text-gray-400"></i>
        <select id="sortOrder" name="sortOrder" class="outline-none focus:outline-none bg-transparent">
            <option value="Default" selected="@(ViewData["CurrentSort"]?.ToString() == "Default")">Default</option>
            <option value="Most Recent" selected="@(ViewData["CurrentSort"]?.ToString() == "Most Recent")">Most Recent</option>
            <option value="Oldest" selected="@(ViewData["CurrentSort"]?.ToString() == "Oldest")">Oldest</option>

        </select>
    </div>
</form>
<div class="flex flex-wrap gap-3 p-12 justify-center items-center">
@foreach (var item in Model) {
    
        <div class="flex flex-row gap-4 max-w-md w-full shadow-sm rounded py-2 px-2">
         <img class="w-[100px] h-[100px] rounded "  src="@Html.DisplayFor(modelItem => item.VenueImageUrl)" alt="Alternate Text" />
         <div class="flex-1">
                <div class="flex justify-between items-center flex-row">
                <p class="text-sm text-green-700 font-medium">@Html.DisplayFor(modelItem => item.VenueCapacity)</p>
                <p class="text-xs text-gray-700 font-normal">@Html.DisplayFor(modelItem => item.CreatedAt)</p>
            </div>
              <p class="text-base font-medium capitalize">@Html.DisplayFor(modelItem => item.VenueName)</p>
                <p class="text-sm text-gray-700 font-normal capitalize"><i class="fa-solid fa-location-dot"></i> @Html.DisplayFor(modelItem => item.VenueLocation)</p>
                <div class="flex justify-between items-center flex-row">
                <a asp-action="Edit" class="text-blue-600 text-sm" asp-route-id="@item.VenueId"><i class="fa-regular fa-pen-to-square"></i></a>
                @* <a asp-action="Details" asp-route-id="@item.VenueId">Details</a> | *@
                    <a asp-action="Delete" class="text-red-600 text-sm" asp-route-id="@item.VenueId"><i class="fa-regular fa-trash-can"></i></a>
           </div>
         </div>
</div>      
}
 </div>
@* // pagination *@
@if (Model.TotalPages > 1)
{
    <div class="flex flex-row gap-3 items-center justify-center mt-6">
        @if (Model.HasPreviousPage)
        {
            <a class="px-3 py-1 rounded bg-gray-200 text-gray-700 hover:bg-gray-300 transition-all text-sm"
            href="@Url.Action("Index", new { pageNumber = Model.PageIndex - 1 })">Previous</a>
        }
        else
        {
            <span class="px-3 py-1 rounded bg-gray-100 text-gray-400 text-sm">Previous</span>
        }

        <p class="text-black px-3">Page @Model.PageIndex of @Model.TotalPages</p>

        @if (Model.HasNextPage)
        {
            <a class="px-3 py-1 rounded bg-gray-200 text-gray-700 hover:bg-gray-300 transition-all text-sm"
            href="@Url.Action("Index", new { pageNumber = Model.PageIndex + 1 })">Next</a>
        }
        else
        {
            <span class="px-3 py-1 rounded bg-gray-100 text-gray-400 text-sm">Next</span>
        }
    </div>
}
<script>
    const searchInput = document.getElementById("searchInput");
    const sortOrder = document.getElementById("sortOrder");
    searchInput.addEventListener("blur", function () {
        let val = searchInput.value.trim();
        if (!val) return;

        // Try to parse as date
        let date = new Date(val);
        if (!isNaN(date.getTime())) {
            // Format as dd/MM/yyyy
            let day = String(date.getDate()).padStart(2, '0');
            let month = String(date.getMonth() + 1).padStart(2, '0');
            let year = date.getFullYear();
            searchInput.value = `${day}/${month}/${year}`;
        }
    });
    let typingTimer;
    searchInput.addEventListener("input", function () {
        clearTimeout(typingTimer);
        typingTimer = setTimeout(() => {
            fetch(`/Venues/Index?searchInput=${encodeURIComponent(searchInput.value)}&sortOrder=${sortOrder.value}`)
                .then(response => response.text())
                .then(html => {
                    document.querySelector(".flex.flex-wrap").innerHTML =
                        new DOMParser().parseFromString(html, "text/html")
                        .querySelector(".flex.flex-wrap").innerHTML;
                });
        }, 500);
    });

    sortOrder.addEventListener("change", function () {
        fetch(`/Venues/Index?searchInput=${encodeURIComponent(searchInput.value)}&sortOrder=${sortOrder.value}`)
            .then(response => response.text())
            .then(html => {
                document.querySelector(".flex.flex-wrap").innerHTML =
                    new DOMParser().parseFromString(html, "text/html")
                    .querySelector(".flex.flex-wrap").innerHTML;
            });
    });
</script>
