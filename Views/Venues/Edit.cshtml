@model Gumani_Moila_ST10229429_CLDV7111w.Models.Venue

@{
    ViewData["Title"] = "Edit";
}

<div class="w-full flex justify-start mb-20 px-4">
    <a href="javascript:history.back()"
       class="inline-flex items-center px-3 py-2 rounded-lg bg-gray-200 text-gray-700 hover:bg-gray-300 transition-all shadow-sm">
        <i class="fa-solid fa-arrow-left mr-2"></i>
        <span>Back</span>
    </a>
</div>
<form asp-action="Edit" class="w-full max-w-2xl mx-auto" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-red-600 text-center"></div>
    <p class="text-lg text-center font-medium mb-6">Edit  user</p>

    <!-- Responsive grid: 2 columns on medium+, 1 column on small -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
            <input type="hidden" asp-for="VenueId" />
  
        <div>
            <label asp-for="VenueName" class="text-sm font-sm"></label>
            <input asp-for="VenueName" placeholder="Enter first name" class="w-full px-3 py-2 rounded-lg border border-gray-300 bg-gray-100 focus:ring-2 focus:ring-blue-600 focus:border-transparent outline-none transition-all" />
            <span asp-validation-for="VenueName" class="text-red-600"></span>
        </div>
     
        <div>
            <label asp-for="VenueLocation" class="text-sm font-sm"></label>
            <input asp-for="VenueLocation" placeholder="Enter first name" class="w-full px-3 py-2 rounded-lg border border-gray-300 bg-gray-100 focus:ring-2 focus:ring-blue-600 focus:border-transparent outline-none transition-all" />
            <span asp-validation-for="VenueLocation" class="text-red-600"></span>
        </div>

        <div>
            <label asp-for="VenueCapacity" class="text-sm font-sm"></label>
            <input asp-for="VenueCapacity" placeholder="Enter first name" class="w-full px-3 py-2 rounded-lg border border-gray-300 bg-gray-100 focus:ring-2 focus:ring-blue-600 focus:border-transparent outline-none transition-all" />
            <span asp-validation-for="VenueCapacity" class="text-red-600"></span>
        </div>
      
        <div>
            <label class="text-sm font-sm">Venue Image</label>
            <input type="file" name="venueImage" class="w-full px-3 py-2 rounded-lg border border-gray-300 bg-gray-100 focus:ring-2 focus:ring-blue-600 focus:border-transparent outline-none transition-all" />
            <span asp-validation-for="VenueImageUrl" class="text-red-600"></span>
        </div>
          </div>
    <!-- Centered button -->
    <div class="flex justify-center mt-6">
        <input type="submit" value="Save" class="w-full px-6 py-2 bg-black text-white rounded-lg hover:bg-blue-700 transition-all" />
    </div>
        </form>


@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
