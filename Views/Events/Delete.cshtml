@model Gumani_Moila_ST10229429_CLDV7111w.Models.Event

@{
    ViewData["Title"] = "Delete";
}
<div class="w-full flex flex-row justify-between items-center mb-20 px-4">
    <a asp-action="Index"
       class="inline-flex items-center px-3 py-2 rounded-lg bg-gray-200 text-gray-700 hover:bg-gray-300 transition-all shadow-sm">
        <i class="fa-solid fa-arrow-left mr-2"></i>
        <span>Back</span>
    </a>
    <form asp-action="Delete">
        <input type="hidden" asp-for="EventId" />
        <input type="submit" value="Delete event" class="bg-red-600 py-1 px-3 text-base text-white font-medium rounded text-center" />
    </form>
</div>

<div class="w-full max-w-2xl mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
      <div>
            <label class="text-sm font-sm">Event name</label>
        <input value="@Html.DisplayFor(model=> model.EventName)" class="w-full px-3 py-2 rounded-lg border border-gray-300 bg-gray-100 outline-none transition-all" readonly />
       
        </div>
        <div>
            <label class="text-sm font-sm">Event date</label>
        <input value="@Html.DisplayFor(model => model.EventDate)" class="w-full px-3 py-2 rounded-lg border border-gray-300 bg-gray-100  outline-none transition-all" readonly />
       </div>
        <div>
            <label class="text-sm font-sm">Event description</label>
        <input value="@Html.DisplayFor(model => model.EventDescription)" class="w-full px-3 py-2 rounded-lg border border-gray-300 bg-gray-100  outline-none transition-all" readonly />
       
        </div>
        <div>
            <label class="text-sm font-sm">Venue name</label>
        <input value="@Html.DisplayFor(model => model.Venue.VenueName)" class="w-full px-3 py-2 rounded-lg border border-gray-300 bg-gray-100 outline-none transition-all" readonly />
       </div>
        <div>
            <label class="text-sm font-sm">Venue Location</label>
        <input value="@Html.DisplayFor(model => model.Venue.VenueLocation)" class="w-full px-3 py-2 rounded-lg border border-gray-300 bg-gray-100 outline-none transition-all" readonly />
        </div>
        <div>
            <label class="text-sm font-sm">Date of creation</label>
        <input value="@Html.DisplayFor(model => model.CreatedAt)"  class="w-full px-3 py-2 rounded-lg border border-gray-300 bg-gray-100  outline-none transition-all" readonly />
     </div>
</div>
</div>