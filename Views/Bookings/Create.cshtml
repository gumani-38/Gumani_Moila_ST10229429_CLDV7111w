@model Gumani_Moila_ST10229429_CLDV7111w.Models.Booking

@{
    ViewData["Title"] = "Create";
}
<div class="w-full flex justify-start mb-20 px-4">
    <a asp-action="Index"
       class="inline-flex items-center px-3 py-2 rounded-lg bg-gray-200 text-gray-700 hover:bg-gray-300 transition-all shadow-sm">
        <i class="fa-solid fa-arrow-left mr-2"></i>
        <span>Back</span>
    </a>
</div>


<form asp-action="Create" class="w-full max-w-2xl mx-auto" method="post">
    @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-red-600 text-center"></div>
    <p class="text-lg text-center font-medium mb-6">Create new booking</p>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">     
        <div>
            <label asp-for="VenueId" class="text-sm font-sm"></label>
            <select asp-for="VenueId" class="w-full px-3 py-2 rounded-lg border border-gray-300 bg-gray-100 focus:ring-2 focus:ring-blue-600 focus:border-transparent outline-none transition-all" asp-items="ViewBag.VenueId"></select>
            <span asp-validation-for="VenueId" class="text-red-600"></span>
        </div>
        <div>
            <label asp-for="EventId" class="text-sm font-sm"></label>
            <select asp-for="EventId" class="w-full px-3 py-2 rounded-lg border border-gray-300 bg-gray-100 focus:ring-2 focus:ring-blue-600 focus:border-transparent outline-none transition-all" asp-items="ViewBag.EventId"></select>
            <span asp-validation-for="EventId" class="text-red-600"></span>
        </div>
        <div>
            <label asp-for="CustomerId" class="text-sm font-sm"></label>
            <select asp-for="CustomerId"
                    id="CustomerId"
                    class="w-full px-3 py-2 rounded-lg border border-gray-300 bg-gray-100"
                    asp-items="ViewBag.CustomerId">
                <option value="">-- Select Customer --</option>
            </select>
            <span asp-validation-for="CustomerId" class="text-red-600"></span>

            <!-- Add new customer link -->
            <div class="mt-2">
                <a asp-controller="CustomerDetails" asp-action="Create"
                   class="text-blue-600 text-sm hover:underline">
                    + Add New Customer
                </a>
            </div>
        </div>
        </div>

    <!-- Centered button -->
    <div class="flex justify-center mt-6">
        <input type="submit" value="Create" class="w-full px-6 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-all" />
    </div>
        </form>


@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}

    <script>
        new TomSelect('#CustomerId', {
            placeholder: "-- Select Customer --",
            allowEmptyOption: true
        });
    </script>



}
